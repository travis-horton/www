{
  "name": "www",
  "version": "2.1.0",
  "description": "website with parcel",
  "scripts": {
    "test": "jest",
    "build": "parcel build ./src/index.html",
    "serve": "parcel serve ./src/index.html",
    "rebuild": "docker stop web; docker-compose build && docker-compose up -d",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiddspazz/www.git"
  },
  "author": "kiddspazz (https://www.travish.com/)",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kiddspazz/www/issues"
  },
  "homepage": "https://github.com/kiddspazz/www#readme",
  "dependencies": {
    "firebase": "^10.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-is": "^18.0.0",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.28.5",
    "@parcel/transformer-image": "^2.12.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^30.2.0",
    "eslint": "^7.32.0 || ^8.2.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "parcel": "^2.12.0",
    "process": "^0.11.10"
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/src/pages/Programming/projects/asteroids/"
    ],
    "moduleNameMapper": {
      "\\.(css|less|sass|scss)$": "<rootDir>/__mocks__/styleMock.js",
      "^url:.+$": "<rootDir>/__mocks__/fileMock.js",
      "\\.(png|jpg|jpeg|gif|svg|ico|pdf|woff|woff2|ttf|eot)$": "<rootDir>/__mocks__/fileMock.js",
      "^/src/(.+)$": "<rootDir>/src/$1",
      "^firebase/app$": "<rootDir>/__mocks__/firebase/app.js",
      "^firebase/database$": "<rootDir>/__mocks__/firebase/database.js"
    },
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": [
        "babel-jest",
        {
          "configFile": false,
          "babelrc": false,
          "presets": [
            "@babel/preset-env",
            "@babel/preset-react",
            "@babel/preset-typescript"
          ]
        }
      ]
    },
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ]
  }
}
